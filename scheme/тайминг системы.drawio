        <mxCell id="Sjoz_kzyMTPhKIuq3549-1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0A58CA;fontColor=#FFFFFF;strokeColor=#0A58CA;strokeWidth=1;fontSize=14;borderRadius=8;" value="&lt;b&gt;&lt;font size=&quot;5&quot;&gt;ТАЙМИНГ СИСТЕМЫ И КОНТУР ПЕРЕХВАТА БПЛА&lt;/font&gt;&lt;/b&gt;&lt;br&gt;Временная шкала от момента первого звукового контакта до физического уничтожения нарушителя" vertex="1">
          <mxGeometry height="70" width="1020" x="60" y="40" as="geometry" />
        </mxCell>
        <mxCell id="Sjoz_kzyMTPhKIuq3549-2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;fontColor=#212529;strokeColor=#0A58CA;strokeWidth=2;fontSize=13;borderRadius=8;" value="&lt;b&gt;1. ДЕТЕКЦИЯ&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#0A58CA&quot;&gt;&lt;b&gt;1.0 сек&lt;/b&gt;&lt;/font&gt;&lt;br&gt;Фиксация звука сонаром ЛЭП. Передача по ВОЛС. Очистка шума 50 Гц." vertex="1">
