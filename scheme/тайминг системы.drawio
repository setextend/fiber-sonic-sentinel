        <mxCell id="Sjoz_kzyMTPhKIuq3549-3" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;fontColor=#212529;strokeColor=#0A58CA;strokeWidth=2;fontSize=13;borderRadius=8;" value="&lt;b&gt;2. ТРИАНГУЛЯЦИЯ&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#0A58CA&quot;&gt;&lt;b&gt;1.5 сек&lt;/b&gt;&lt;/font&gt;&lt;br&gt;ИИ-сервер вычисляет 3D-координаты, скорость и высоту дрона по TDOA." vertex="1">
